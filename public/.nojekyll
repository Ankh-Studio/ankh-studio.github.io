<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ankh Studio</title>
    <link rel="stylesheet" href="assets/css/styles.css">
    <meta name="description" content="Official website of Ankh Studio">
</head>
<body>
    <header>
        <div class="container">
            <h1>Ankh Studio</h1>
            <nav>
                <ul>
                    <li><a href="#about">About</a></li>
                    <li><a href="#projects">Projects</a></li>
                    <li><a href="#contact">Contact</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main>
        <section id="hero">
            <div class="container">
                <h2>Welcome to Ankh Studio</h2>
                <p>Creating innovative digital experiences</p>
            </div>
        </section>

        <section id="about">
            <div class="container">
                <h2>About Us</h2>
                <p>Ankh Studio is dedicated to developing creative solutions and building amazing digital experiences.</p>
            </div>
        </section>

        <section id="projects">
            <div class="container">
                <h2>Our Projects</h2>
                <div class="project-grid">
                    <!-- Project cards will go here -->
                    <div class="project-card">
                        <h3>Project 1</h3>
                        <p>Description of first project</p>
                    </div>
                    <div class="project-card">
                        <h3>Project 2</h3>
                        <p>Description of second project</p>
                    </div>
                </div>
            </div>
        </section>

        <section id="contact">
            <div class="container">
                <h2>Contact Us</h2>
                <p>Get in touch with us at <a href="mailto:contact@ankhstudio.com">contact@ankhstudio.com</a></p>
            </div>
        </section>
    </main>

    <footer>
        <div class="container">
            <p>&copy; 2025 Ankh Studio. All rights reserved.</p>
        </div>
    </footer>
</body>
</html>
